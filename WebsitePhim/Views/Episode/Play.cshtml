@model WebsitePhim.Models.Episode

@{
    ViewData["Title"] = $"Tập {Model.EpisodeNumber}: {Model.Title}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-3">🎬 @Model.Movie?.Title - Tập @Model.EpisodeNumber</h2>

<iframe width="100%" height="480" src="@Model.VideoUrl" frameborder="0" allowfullscreen></iframe>

<p class="mt-3">⏱ Đăng lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>

<a asp-controller="Movie" asp-action="Details" asp-route-id="@Model.MovieId" class="btn btn-secondary mt-2">
    ⬅️ Quay lại phim
</a>
