@model IEnumerable<WebsitePhim.Models.Movie>
@{
    ViewData["Title"] = "Trang chủ phim";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var selectedGenre = Context.Request.Query["genreId"].ToString();
    var selectedYear = Context.Request.Query["year"].ToString();
}

<div class="position-relative mb-4">
    <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
        <div class="carousel-inner" style="max-height: 280px; overflow: hidden;">
            @{
                var banners = new[]
                {
            new { Src = "https://static1.moviewebimages.com/wordpress/wp-content/uploads/photo/w247uNbZKUPhfY18mzZ77fAdhpXHVV.jpg", Caption = "", ActionUrl = Url.Action("Index", "Movie") },
            new { Src = "https://weliveentertainment.com/wp-content/uploads/2024/02/madame-web-banner-4.jpg", Caption = "", ActionUrl = Url.Action("Details", "Movie", new { id = 1 }) },
            new { Src = "https://lumiere-a.akamaihd.net/v1/images/250224-8_crtv_andor_s2_payoff_hero_banner_web-2048x878_023c2989.jpeg", Caption = "", ActionUrl = Url.Action("Details", "Movie", new { id = 2 }) }
            };

                for (int i = 0; i < banners.Length; i++)
                {
                    var banner = banners[i];
                    var activeClass = i == 0 ? "active" : "";
                    <div class="carousel-item @activeClass position-relative">
                        <img src="@banner.Src" class="d-block w-100" style="height: 100%; object-fit: cover;" />
                        <div class="carousel-caption d-block">
                            <h5>@banner.Caption</h5>
                            <a href="@banner.ActionUrl" class="btn btn-primary btn-sm mt-2">Xem Ngay</a>
                        </div>
                    </div>
                }
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <h5>Lọc phim</h5>

        <form asp-action="ByGenre" method="get" class="mb-3">
            <select name="genreId" class="form-select mb-2" onchange="this.form.submit()">
                <option value="">-- Tất cả thể loại --</option>
                @foreach (var g in ViewBag.Genres)
                {
                    <option value="@g?.Value" selected="@(g?.Value == selectedGenre ? "selected" : null)">
                        @g?.Text
                    </option>
                }
            </select>
        </form>

        <form asp-action="ByYear" method="get">
            <select name="year" class="form-select" onchange="this.form.submit()">
                <option value="">-- Tất cả năm --</option>
                @foreach (var y in ViewBag.Years)
                {
                    <option value="@y?.Value" selected="@(y?.Value?.ToString() == selectedYear ? "selected" : null)">
                        @y?.Text
                    </option>
                }
            </select>
        </form>

        @await Component.InvokeAsync("TopRatedMovies")
    </div>

    <div class="col-md-9">
        <form asp-action="Search" method="get" class="input-group mb-3">
            <input type="text" name="query" class="form-control" placeholder="🔍 Tìm tên phim..." />
            <button class="btn btn-outline-warning" type="submit">Tìm</button>
        </form>

        <h5> Danh sách phim</h5>
        @if (Model?.Any() ?? false)
        {
            <div class="row">
                @foreach (var movie in Model)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm">
                            <a asp-action="Details" asp-route-id="@movie.Id" class="text-decoration-none text-white">
                                <div class="card-img-container">
                                    <img src="@movie.ImageUrl" class="card-img-top" alt="@movie.Title" />
                                    <div class="card-img-overlay"></div> <div class="card-title-overlay">
                                        <h5 class="text-white">@movie.Title</h5>
                                        <button class="btn btn-primary btn-sm">Xem ngay</button>
                                    </div>
                                </div>
                            </a>
                            <div class="card-body">
                                <h6 class="card-title">@movie.Title</h6>
                                <p class="text-muted">@movie.Genre?.Name (@(movie.ReleaseYear?.ToString() ?? "N/A"))</p>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                Không tìm thấy phim phù hợp. Hãy thử từ khóa khác hoặc xoá bộ lọc.
            </div>
        }
    </div>
</div>