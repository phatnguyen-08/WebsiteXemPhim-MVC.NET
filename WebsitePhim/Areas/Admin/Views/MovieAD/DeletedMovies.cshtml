@model IEnumerable<WebsitePhim.Models.Movie>

@{
    ViewData["Title"] = "Phim Đã Ẩn";
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="h5 mb-0 text-gray-800">Danh sách Phim Đã Ẩn</h4>
            <div>
                <a asp-action="Index" class="btn btn-info btn-sm">
                    <i class="fas fa-film"></i> Quay lại Quản lý Phim
                </a>
            </div>
        </div>
    </div>
    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info text-center" role="alert">
                Hiện không có phim nào đang bị ẩn.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="thead-light">
                        <tr>
                            <th>Tên Phim</th>
                            <th>Thể loại</th>
                            <th>Năm Phát Hành</th>
                            <th>Trạng thái</th>
                            <th style="width: 150px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                                <td>@Html.DisplayFor(modelItem => item.Genre.Name)</td>
                                <td>@Html.DisplayFor(modelItem => item.ReleaseYear)</td>
                                <td>
                                    <span class="badge badge-danger">Đã ẩn</span>
                                </td>
                                <td>
                                    <form asp-action="Restore" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn khôi phục phim này?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="fas fa-undo"></i> Khôi phục
                                        </button>
                                    </form>
                                    @* <form asp-action="PermanentDelete" method="post" style="display:inline;" onsubmit="return confirm('Cảnh báo! Bạn có chắc chắn muốn XÓA VĨNH VIỄN phim này? Thao tác này không thể hoàn tác!');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger ml-1">
                                            <i class="fas fa-times-circle"></i> Xóa vĩnh viễn
                                        </button>
                                    </form> *@
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
