@model WebsitePhim.Models.Movie

@{
    ViewData["Title"] = "Xác Nhận Ẩn Phim";
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <h4 class="h5 mb-0 text-gray-800">Xác Nhận Ẩn Phim</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">Bạn có chắc chắn muốn ẩn phim này không?</h4>
            <p>Phim này sẽ không còn hiển thị cho người dùng cuối. Bạn có thể khôi phục lại sau từ danh sách "Phim đã ẩn".</p>
        </div>

        <dl class="row">
            <dt class="col-sm-2">Tên Phim:</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Title)</dd>

            <dt class="col-sm-2">Mô tả:</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>

            <dt class="col-sm-2">Năm Phát Hành:</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.ReleaseYear)</dd>

            <dt class="col-sm-2">Thể loại:</dt>
            <dd class="col-sm-10">@(Model.Genre?.Name ?? "N/A")</dd>

            <dt class="col-sm-2">Ảnh Poster:</dt>
            <dd class="col-sm-10">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title Poster" style="max-width: 150px; height: auto; border-radius: 5px;" />
                }
                else
                {
                    <span>Không có ảnh</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash-alt"></i> Xác Nhận Ẩn Phim</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ml-2"><i class="fas fa-arrow-left"></i> Hủy bỏ</a>
        </form>
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
