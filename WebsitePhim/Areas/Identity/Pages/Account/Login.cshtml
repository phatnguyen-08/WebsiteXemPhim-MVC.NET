@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: url('https://cdn.mos.cms.futurecdn.net/rDJegQJaCyGaYysj2g5XWY.jpg') no-repeat center center fixed;
            background-size: cover;
        }

        body {
            padding-top: 80px; /* Để tránh bị header che */
        }

        header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

        .navbar {
            background-color: rgba(0, 0, 0, 0.6);
            padding-left: 2rem;
            padding-right: 2rem;
        }

        .nav-link {
            color: #fff !important;
        }

        .login-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 80px);
            padding: 20px;
        }

        .login-box {
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 40px 30px;
            border-radius: 15px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
            color: white;
            width: 100%;
            max-width: 400px;
        }

            .login-box h2 {
                color: #ff8800;
                margin-bottom: 20px;
            }

            .login-box label,
            .login-box a {
                color: #ffffff;
            }

        .form-control {
            background-color: rgba(255, 255, 255, 0.15);
            color: #f1f1f1;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
        }

            .form-control::placeholder {
                color: #ccc;
            }

            .form-control:focus {
                background-color: rgba(255, 255, 255, 0.25);
                color: white;
                outline: none;
                box-shadow: none;
            }

        .form-floating label {
            color: #ccc;
        }

        button[type="submit"] {
            background-color: #ff8800;
            border: none;
        }

            button[type="submit"]:hover {
                background-color: #ff6a00;
                transition: all 0.3s ease-in-out;
            }

        .checkbox label {
            font-size: 0.95rem;
        }

        .login-box a:hover {
            text-decoration: underline;
            color: #ff8800;
        }

        .navbar-brand img {
            height: 42px;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="d-flex w-100 justify-content-between align-items-center">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/WebsitePhim_Logo.png" alt="Logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between w-100">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movie" asp-action="Index">Trang chủ</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- Login Form -->
    <div class="login-container">
        <div class="login-box">
            <form id="account" method="post">
                <h2 class="text-center">Đăng nhập</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Email" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Mật khẩu" />
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="checkbox mb-3 text-start">
                    <label>
                        <input class="form-check-input me-1" asp-for="Input.RememberMe" />
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold">Đăng nhập</button>

                <div class="mt-3 text-center">
                    <a asp-page="./ForgotPassword">Quên mật khẩu?</a> |
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>